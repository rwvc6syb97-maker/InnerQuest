{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "Dockerfile",
    "dockerfilePath": "apps/api/Dockerfile",
    "context": "."
  },
  "deploy": {
    "startCommand": "npx prisma migrate deploy && node dist/main.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  },
  "services": {
    "api": {
      "name": "innerquest-api",
      "build": {
        "builder": "Dockerfile",
        "dockerfilePath": "apps/api/Dockerfile",
        "context": "."
      },
      "deploy": {
        "startCommand": "npx prisma migrate deploy && node dist/main.js",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      }
    }
  },
  "env": {
    "NODE_ENV": "production",
    "PORT": "3000",
    "TZ": "Asia/Shanghai",
    "CORS_ORIGIN": "*",
    "JWT_ACCESS_TTL": "2h",
    "JWT_REFRESH_TTL": "30d"
  }
}